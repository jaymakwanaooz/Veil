{
  "expo": {
    "name": "Veil",
    "slug": "veil",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/veil_logo_v2.png",
    "userInterfaceStyle": "dark",
    "updates": {
      "enabled": false
    },
    "splash": {
      "image": "./assets/veil_logo_v2.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D1A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.veil.chat"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/veil_logo_v2.png",
        "backgroundColor": "#0D0D1A"
      },
      "package": "com.veil.chat"
    },
    "web": {
      "favicon": "./assets/veil_logo_v2.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-asset"
    ]
  }
}