diff --git a/node_modules/react-native-worklets/android/build/prefab-headers/worklets/worklets/Tools/WorkletsJSIUtils.h b/node_modules/react-native-worklets/android/build/prefab-headers/worklets/worklets/Tools/WorkletsJSIUtils.h
